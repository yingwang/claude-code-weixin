{
  "name": "claude-channel-weixin",
  "version": "0.2.7",
  "description": "WeChat channel plugin for Claude Code — chat with Claude Code from WeChat",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-channel-weixin": "dist/install.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
